# ==================================================
# 🔐 Environment & secrets
# ==================================================
.env
.env.*
!.env.example

# ==================================================
# 🐍 Python bytecode / cache
# ==================================================
__pycache__/
*.py[cod]
*$py.class

# ==================================================
# 🧪 Virtual environment (your project uses .venv)
# ==================================================
.venv/
venv/
env/
ENV/

# ==================================================
# 🗄 Django database (local dev)
# ==================================================
db.sqlite3
db.sqlite3-journal

# ==================================================
# 🎨 Django static & media (generated)
# ==================================================
staticfiles/
media/

# ==================================================
# 🧪 Django test / coverage
# ==================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ==================================================
# 📜 Logs
# ==================================================
*.log

# ==================================================
# 🧰 Django / project-specific
# ==================================================
local_settings.py
settings_local.py

# ==================================================
# 🎨 Tailwind / Node (django-tailwind)
# ==================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/dist/
frontend/build/

# ==================================================
# 🛠 IDE / Editor
# ==================================================
.vscode/
.idea/
*.swp
*.swo

# ==================================================
# 🖥 OS files
# ==================================================
.DS_Store
Thumbs.db

# ==================================================
# 📦 Packaging / build
# ==================================================
build/
dist/
*.egg-info/
.eggs/

# ==================================================
# ✅ Explicitly tracked files (DO NOT IGNORE)
# ==================================================
!requirements.txt
